{
  "id": "funkycode",
  "name": "FunkyCode",
  "description": "Cinematic code-typing animations (deterministic headless-Chromium canvas capture).",
  "cwd": "../funkycode",
  "command": ["npx", "tsx", "scripts/render-funky.mts", "{input}", "{output}"],
  "inputKind": "funkyScenes",
  "inputExt": ".json",
  "outputExt": "mp4",
  "probeBinary": "scripts/render-funky.mts",
  "buildHint": "Run `npm install` in funkycode (adds playwright + esbuild + tsx).",
  "params": [
    { "flag": "--fps", "label": "FPS", "type": "string", "default": "30" },
    { "flag": "--shorts", "label": "Vertical (1080x1920)", "type": "bool", "default": "" }
  ]
}
