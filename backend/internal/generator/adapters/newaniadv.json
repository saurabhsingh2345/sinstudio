{
  "id": "newaniadv",
  "name": "newaniAdv",
  "description": "Narrated code/tutorial clips from a JSON lesson DSL (deterministic canvas + Kokoro TTS).",
  "cwd": "../newaniAdv",
  "command": ["npx", "tsx", "scripts/render-video.mts", "{input}", "{output}"],
  "inputKind": "lessonJson",
  "inputExt": ".json",
  "outputExt": "mp4",
  "buildHint": "Run `npm install` in newaniAdv so `npx tsx` is available.",
  "params": [
    {
      "flag": "--voice",
      "label": "Voice",
      "type": "enum",
      "default": "af_heart",
      "options": ["af_heart", "af_bella", "am_michael", "bf_emma", "bm_george"]
    },
    { "flag": "--shorts", "label": "Vertical (1080x1920)", "type": "bool", "default": "" },
    { "flag": "--no-voice", "label": "Mute narration", "type": "bool", "default": "" }
  ]
}
